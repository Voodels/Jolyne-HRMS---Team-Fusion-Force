# Backend Environment Variables
# Copy this file to .env and fill in the values

# Database (Neon PostgreSQL)
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/db?sslmode=require

# Cloudinary (Resume Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Affinda (Resume Parsing)
AFFINDA_API_KEY=aff_your_api_key_here

# SMTP Email settings for OTP delivery
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-smtp-username
SPRING_MAIL_PASSWORD=your-smtp-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true

# Optional: Spring Profile
SPRING_PROFILES_ACTIVE=dev

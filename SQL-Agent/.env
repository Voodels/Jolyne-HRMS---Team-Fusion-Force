# LLM provider switch (set MODEL_PROVIDER and matching model below)
# - Ollama: MODEL_PROVIDER=ollama + OLLAMA_MODEL=...
# - Groq:   MODEL_PROVIDER=groq + GROQ_MODEL=...
# - Gemini: MODEL_PROVIDER=gemini + GEMINI_MODEL=...
MODEL_PROVIDER=ollama
OLLAMA_MODEL=minimax-m2.1:cloud
# qwen3-coder:480b-cloud
# gpt-oss:120b-cloud
# minimax-m2.7:cloud 
# gemma3:27b-cloud
OLLAMA_BASE_URL=http://localhost:11434
# # SCHEMA_CACHE=0
# MODEL_PROVIDER=groq
# GROQ_MODEL=llama-3.1-8b-instant
# MODEL_PROVIDER=openai_compat
# OPENAI_BASE_URL=http://127.0.0.1:8001/v1
# OPENAI_MODEL=gemini-cli
# OPENAI_API_KEY=local-key

# RAG (ChromaDB)
RAG_ENABLED=1
RAG_MODE=auto
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=candidates
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.2
RAG_MAX_CONTEXT_CHARS=2000
RAG_AUTO_INDEX=1
RAG_INDEX_LIMIT=1000
RAG_SYNC_INTERVAL_SECONDS=30
RAG_SYNC_LIMIT=500